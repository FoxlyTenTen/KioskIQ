# ============================================================
# KioskIQ — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ============================================================
# Supabase (required)
# Get these from: https://app.supabase.com → Project Settings → API
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# ============================================================
# OpenAI (required — used for RAG embeddings)
# Get your key from: https://platform.openai.com/api-keys
# ============================================================

OPENAI_API_KEY=sk-...


# ============================================================
# ILMU (required — LLM for orchestrator via Anthropic-compatible endpoint)
# ============================================================

ILMU_API_KEY=your_ilmu_api_key_here
ILMU_MODEL=ilmu-glm-5.1
ANTHROPIC_BASE_URL=https://api.ilmu.ai/anthropic


# ============================================================
# Google Gemini (required — used by A2A sub-agents)
# Get your key from: https://aistudio.google.com/app/apikey
# ============================================================

GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash


# ============================================================
# MongoDB Atlas (optional — used by database agent)
# Get your URI from: https://cloud.mongodb.com
# ============================================================

MONGODB_ATLAS_CLUSTER_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname


# ============================================================
# MCP Server URLs (Next.js → Python MCP servers)
# These tell the orchestrator where to find the MCP tools.
# Change only if you run the servers on non-default ports.
# ============================================================

RAG_MCP_URL=http://localhost:9013/sse
SQL_MCP_URL=http://localhost:9014/sse


# ============================================================
# Agent URLs (Next.js frontend → Python agents)
# Change only if you run agents on non-default ports.
# ============================================================

ORCHESTRATOR_URL=http://localhost:9000
COACH_AGENT_URL=http://localhost:9002
DATABASE_AGENT_URL=http://localhost:9003
PRODUCT_AGENT_URL=http://localhost:9004
INVESTMENT_AGENT_URL=http://localhost:9005
FEASIBILITY_AGENT_URL=http://localhost:9006
PLANNER_AGENT_URL=http://localhost:9007
SUMMARY_AGENT_URL=http://localhost:9008


# ============================================================
# Agent Ports (Python agents — which port each server binds to)
# Must match the Agent URLs above.
# ============================================================

ORCHESTRATOR_PORT=9000
RAG_MCP_PORT=9013
SQL_MCP_PORT=9014
COACH_PORT=9002
DATABASE_PORT=9003
PRODUCT_PORT=9004
INVESTMENT_PORT=9005
FEASIBILITY_PORT=9006
PLANNER_PORT=9007
SUMMARY_PORT=9008
