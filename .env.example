# ============================================================
# Inventra — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ============================================================
# Supabase (required)
# Get these from: https://app.supabase.com → Project Settings → API
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# ============================================================
# OpenAI (required — used for RAG embeddings)
# Get your key from: https://platform.openai.com/api-keys
# ============================================================

OPENAI_API_KEY=sk-...


# ============================================================
# ILMU (required — GLM-5.1 core brain for orchestrator)
# Get your key from: https://ilmu.ai
# ============================================================

ILMU_API_KEY=your_ilmu_api_key_here
ILMU_MODEL=ilmu-glm-5.1
ANTHROPIC_BASE_URL=https://api.ilmu.ai/anthropic


# ============================================================
# Google Gemini (required — used by all A2A sub-agents)
# Get your key from: https://aistudio.google.com/app/apikey
# ============================================================

GOOGLE_API_KEY=your_google_api_key_here


# ============================================================
# Google Maps (required — used by Site Selection & Market Research agents)
# Get your key from: https://console.cloud.google.com
# ============================================================

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ============================================================
# Foursquare (required — used by Site Selection agent for foot traffic)
# Get your key from: https://foursquare.com/developers
# ============================================================

FOURSQUARE_API_KEY=your_foursquare_api_key_here


# ============================================================
# CopilotKit (optional — for CopilotKit Cloud)
# ============================================================

NEXT_PUBLIC_COPILOT_CLOUD_API_KEY=your_copilotkit_cloud_key_here


# ============================================================
# Agent URLs (Next.js → Python agents)
# Change only if you run agents on non-default ports.
# ============================================================

ORCHESTRATOR_URL=http://localhost:9000
SITE_SELECTION_AGENT_URL=http://localhost:9020
EXPANSION_FEASIBILITY_AGENT_URL=http://localhost:9021
MARKET_RESEARCHER_AGENT_URL=http://localhost:9022
RISK_MANAGER_AGENT_URL=http://localhost:9023
STRATEGIC_PLANNER_AGENT_URL=http://localhost:9024
FORECAST_AGENT_URL=http://localhost:9025


# ============================================================
# Agent Ports (Python agents — which port each server binds to)
# ============================================================

ORCHESTRATOR_PORT=9000
RAG_MCP_PORT=9013
SQL_MCP_PORT=9014
SITE_SELECTION_PORT=9020
EXPANSION_FEASIBILITY_PORT=9021
MARKET_RESEARCHER_PORT=9022
RISK_MANAGER_PORT=9023
STRATEGIC_PLANNER_PORT=9024
FORECAST_AGENT_PORT=9025
